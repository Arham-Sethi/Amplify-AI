{
  "version": "v1",
  "category": "role_persona",
  "description": "Prompt that assigns the model a role or persona ('act as', 'you are', etc.) and then asks it to perform a task within that frame.",
  "pass_threshold": 70,
  "checks": [
    {
      "id": "role_assigned",
      "weight": 15,
      "test": "regex",
      "pattern": "\\b(you are|act as|you're|imagine you are|play the role of|pretend to be|assume the role of|take on the role of)\\b",
      "description": "Role is explicitly assigned with one of the canonical phrasings."
    },
    {
      "id": "role_specific",
      "weight": 15,
      "test": "regex",
      "pattern": "\\b(senior|principal|expert|experienced|specialist|certified|tenured|world[- ]class|head of|lead|chief)\\b",
      "description": "Role has a seniority or specialization qualifier rather than just 'a developer'."
    },
    {
      "id": "domain_named",
      "weight": 15,
      "test": "regex",
      "pattern": "\\b(in|at|for|on)\\s+\\w+(?:\\s+\\w+){0,3}",
      "description": "Domain is named after the role (e.g. 'in fintech', 'at a Series B startup', 'for healthcare compliance')."
    },
    {
      "id": "task_separate_from_role",
      "weight": 10,
      "test": "regex",
      "pattern": "\\b(write|draft|review|analyze|design|critique|explain|summarize|recommend|plan|generate|produce|create|propose|evaluate)\\b",
      "description": "An actual task verb is present — the role on its own isn't a prompt."
    },
    {
      "id": "constraints_present",
      "weight": 10,
      "test": "regex",
      "pattern": "\\b(must|should|avoid|don't|do not|exclude|focus on|prioritize|consider|account for|take into account)\\b",
      "description": "At least one explicit constraint or guardrail."
    },
    {
      "id": "format_specified",
      "weight": 10,
      "test": "has_format_directive",
      "description": "Output format is constrained."
    },
    {
      "id": "tone_specified",
      "weight": 10,
      "test": "regex",
      "pattern": "\\b(formal|casual|professional|friendly|neutral|playful|concise|terse|warm|technical|plain|direct|empathetic)\\b",
      "description": "Tone is named."
    },
    {
      "id": "audience_specified",
      "weight": 10,
      "test": "has_audience_directive",
      "description": "Audience is named."
    },
    {
      "id": "no_meta_filler",
      "weight": 5,
      "test": "not_regex",
      "pattern": "\\b(please can you|i was wondering if|could you maybe|if it's not too much)\\b",
      "description": "No throat-clearing meta language."
    }
  ]
}
