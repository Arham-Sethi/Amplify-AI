# Supabase — get from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key
# Public anon/publishable key — safe to expose to the browser. RLS enforces access.
SUPABASE_ANON_KEY=eyJ...your-anon-key

# Resend — get from https://resend.com/api-keys
RESEND_API_KEY=re_...your-api-key

# App config
APP_URL=https://your-domain.com
FROM_EMAIL=Amplify AI <noreply@your-domain.com>
